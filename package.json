{
  "name": "mahin-handmade-commerce",
  "version": "1.0.0",
  "private": true,
  "description": "Premium handmade crafts eCommerce platform with public storefront and secure admin dashboard.",
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "frontend",
    "admin",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:admin": "npm --workspace admin run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build",
    "build:all": "npm --workspace frontend run build && npm --workspace admin run build",
    "seed:admin": "npm --workspace backend run seed:admin"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "rollup": "3.30.0",
    "vite": "4.5.5"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "browserslist": "^4.28.2",
    "caniuse-lite": "^1.0.30001792"
  },
  "overrides": {
    "rollup": "3.30.0",
    "vite": "4.5.5"
  }
}
